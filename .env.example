# VisPay Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to GitHub

# ── Razorpay Test Mode Keys ───────────────────────────────────────────────────
# Get your free test keys at: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database (relative to src/)
DB_PATH=vispay_transactions.db

# ── TTS (Text-to-Speech) ─────────────────────────────────────────────────────
# Options: edge (Microsoft Edge TTS), gtts (Google TTS), print (no audio)
TTS_ENGINE=edge

# ── Input Mode ───────────────────────────────────────────────────────────────
# Options: both (voice + keyboard), voice, keyboard
INPUT_MODE=both
